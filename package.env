# Configuration for the Debian package

# The upstream GitHub repository (e.g., junegunn/fzf, sharkdp/bat)
UPSTREAM_REPO="junegunn/fzf"

# The name of the Debian package you want to create
PACKAGE_NAME="fzf"

# Maintainer information for the Debian control file
MAINTAINER="Vincent <vincent@example.com>"

# Short description of the package
DESCRIPTION="A command-line fuzzy finder"

# Homepage URL
HOMEPAGE="https://github.com/junegunn/fzf"

# License (e.g., MIT, GPL-3.0, Apache-2.0)
LICENSE="MIT"
